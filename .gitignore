serviceAccountKey.json
firebase-service-account*.json
.firebase/

# Python
__pycache__/
*.pyc
.venv/
venv/

# 編輯器與系統
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.log

# Excel 暫存鎖定檔
~$*.xlsx

# 當事人個資來源檔（含姓名/住址/電話，不可進版控）
*.xlsx
