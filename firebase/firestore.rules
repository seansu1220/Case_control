rules_version = '2';

// Firestore 安全規則：權限的「最終防線」。
// 即使前端被繞過，下列規則仍會在資料庫層阻擋未授權的讀寫。
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function callerData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // 具管理權限：管理者或所有人。
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (callerData().role == 'admin' || callerData().role == 'owner');
    }

    // ── 使用者 ──
    match /users/{uid} {
      // 只能讀自己的資料；管理者/所有人可讀全部。
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // 自行註冊：只能建立自己的文件，且角色強制為 lawyer、預設啟用、預設可看全部，
      // 防止自我提權為管理者/所有人。
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.role == 'lawyer'
        && request.resource.data.active == true;

      // 更新：
      //  - 本人僅能改自己的顯示名稱與律師姓名（含所有人，但不得改 role/active）。
      //  - 管理者/所有人可管理他人，但「所有人」帳號受保護：不可被修改，
      //    且不得將任何人提權為 owner（owner 僅能於主控台手動指派）。
      allow update: if (request.auth.uid == uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'lawyerName']))
        || (isAdmin()
            && resource.data.role != 'owner'
            && request.resource.data.role != 'owner');

      // 刪除使用者：管理者/所有人可刪，但不可刪除「所有人」帳號。
      allow delete: if isAdmin() && resource.data.role != 'owner';
    }

    // ── 案件 ──
    match /cases/{caseId} {
      function isOwner() {
        return isSignedIn() && resource.data.responsibleLawyerUid == request.auth.uid;
      }

      // 可看全部案件者：開啟 viewAllCases 的登入者（預設開啟）。
      function canViewAll() {
        return isSignedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && callerData().get('viewAllCases', true) == true;
      }

      // 管理者/所有人可讀全部；律師讀自己負責的，或在 viewAllCases 開啟時讀全部。
      allow read: if isAdmin() || isOwner() || canViewAll();

      // 新增：建立者必須是自己；負責律師須為自己，或由管理者代為指派。
      allow create: if isSignedIn()
        && request.resource.data.createdByUid == request.auth.uid
        && (isAdmin() || request.resource.data.responsibleLawyerUid == request.auth.uid);

      // 刪除：本人或管理者（律師僅能刪自己的）。
      allow delete: if isAdmin() || isOwner();

      // 更新：
      //  - 管理者：不受限（含重新開啟案件）。
      //  - 擁有者且未結案：可自由編輯。
      //  - 擁有者且已結案：僅允許修改 taxStatus（與 updatedAt）。
      allow update: if isAdmin()
        || (isOwner() && resource.data.closed == false)
        || (isOwner()
            && resource.data.closed == true
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['taxStatus', 'updatedAt']));
    }

    // ── 詞彙清單（類型 / 委任範圍等下拉選項）──
    match /vocabularies/{listId} {
      // 任何登入者可讀（表單需要選項）。
      allow read: if isSignedIn();

      // 建立清單文件：任何登入者皆可（首次新增選項時自動建立）。
      allow create: if isSignedIn();

      // 更新：管理者不受限（改名 / 刪除 / 排序）；
      // 一般律師僅能「新增」選項（選項數量增加），用於「其他」加入常用清單。
      allow update: if isAdmin()
        || (isSignedIn()
            && request.resource.data.values.size() > resource.data.values.size());

      // 刪除整份清單僅限管理者。
      allow delete: if isAdmin();
    }
  }
}
